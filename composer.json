{
	"name": "mediawiki/parser-hooks",
	"type": "library",
	"description": "OOP and declarative parser hook interface on top of MediaWiki",
	"keywords": [
		"parserhooks",
		"mediawiki",
		"parser function",
		"parser hook",
		"tag extension"
	],
	"homepage": "https://github.com/JeroenDeDauw/ParserHooks",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Jeroen De Dauw",
			"email": "jeroendedauw@gmail.com",
			"homepage": "https://www.entropywins.wtf"
		}
	],
	"require": {
		"php": ">=8.1",
		"param-processor/param-processor": "^1.12"
	},
	"require-dev": {
		"mediawiki/mediawiki-codesniffer": "^45.0.0"
	},
	"autoload": {
		"psr-4": {
			"ParserHooks\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"ParserHooks\\Tests\\": "tests/phpunit/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
